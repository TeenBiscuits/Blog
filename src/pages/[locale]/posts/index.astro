---
import { getEmDashCollection, getTermsForEntries } from 'emdash'
import { Image } from 'emdash/ui'
import { getRelativeLocaleUrl } from 'astro:i18n'
import Base from '../../../layouts/Base.astro'
import { formatDate, type Locale } from '../../../i18n/utils'

const locale = (Astro.currentLocale ?? 'es') as Locale

const { entries: posts, cacheHint } = await getEmDashCollection('posts', {
	orderBy: { published_at: 'desc' },
	locale,
})

if (Astro.cache?.enabled) Astro.cache.set(cacheHint)

const tagsByEntry = await getTermsForEntries(
	'posts',
	posts.map((p) => p.data.id),
	'tag'
)

const postsWithTags = posts.map((post) => ({
	post,
	tags: tagsByEntry.get(post.data.id) ?? [],
	bylines: post.data.bylines ?? [],
}))
---

<Base title="Articulos" description="Todos los articulos del blog">
	<div class="posts-page">
		<header class="page-header">
			<h1 class="page-title">Articulos</h1>
			<div class="page-subtitle">
				<span>{posts.length} {posts.length === 1 ? 'articulo' : 'articulos'}</span>
			</div>
		</header>

		{
			posts.length === 0 ? (
				<p class="empty">No hay articulos aun.</p>
			) : (
				<div class="posts-list">
					{postsWithTags.map(({ post }) => (
						<article class="post-item">
							{post.data.featured_image && (
								<a href={getRelativeLocaleUrl(locale, `/posts/${post.id}`)} class="post-image-link">
									<div class="post-image">
										<Image image={post.data.featured_image} />
									</div>
								</a>
							)}
							<div class="post-content">
								<a href={getRelativeLocaleUrl(locale, `/posts/${post.id}`)} class="post-link">
									<h2 class="post-title">{post.data.title}</h2>
								</a>
								{post.data.excerpt && (
									<p class="post-excerpt">{post.data.excerpt}</p>
								)}
								<div class="post-meta">
									{post.data.publishedAt && (
										<time>{formatDate(post.data.publishedAt, locale)}</time>
									)}
								</div>
							</div>
						</article>
					))}
				</div>
			)
		}
	</div>
</Base>

<style>
	.posts-page {
		max-width: var(--wide-width);
		margin: 0 auto;
		padding: var(--spacing-12) var(--spacing-6) var(--spacing-16);
	}

	.page-header {
		margin-bottom: var(--spacing-12);
	}

	.page-title {
		font-family: var(--font-serif, var(--font-sans));
		font-size: 4.625rem;
		font-weight: 700;
		line-height: 1.06;
		letter-spacing: -0.015em;
		color: var(--color-text);
		margin-bottom: var(--spacing-3);
	}

	.page-subtitle {
		font-family: var(--font-sans);
		font-size: var(--font-size-sm);
		color: var(--color-muted);
	}

	.empty {
		color: var(--color-muted);
		font-size: var(--font-size-lg);
	}

	.posts-list {
		display: flex;
		flex-direction: column;
	}

	.post-item {
		display: flex;
		background: var(--color-surface);
		border: 1px solid var(--color-border);
		margin-bottom: var(--spacing-4);
	}

	.post-item:last-child {
		margin-bottom: 0;
	}

	.post-image-link {
		display: flex;
		width: 430px;
		height: 250px;
		flex-shrink: 0;
	}

	.post-image {
		width: 100%;
		height: 100%;
		background: var(--color-sand);
	}

	.post-image img {
		width: 100%;
		height: 100%;
		object-fit: cover;
	}

	.post-content {
		display: flex;
		flex-direction: column;
		flex: 1;
		padding: var(--spacing-6) 1.875rem;
		gap: 0.875rem;
	}

	.post-link {
		text-decoration: none;
		color: inherit;
	}

	.post-title {
		font-family: var(--font-serif, var(--font-sans));
		font-size: 2.375rem;
		font-weight: 700;
		line-height: 1.16;
		color: var(--color-text);
		transition: color var(--transition-fast);
	}

	.post-link:hover .post-title {
		color: var(--color-text-secondary);
	}

	.post-excerpt {
		font-family: var(--font-sans);
		font-size: var(--font-size-xl);
		line-height: 1.55;
		color: var(--color-text-secondary);
	}

	.post-meta {
		font-family: var(--font-sans);
		font-size: 0.9375rem;
		color: var(--color-muted);
	}

	@media (max-width: 900px) {
		.post-image-link {
			width: 100%;
			height: 200px;
		}

		.post-item {
			flex-direction: column;
		}

		.page-title {
			font-size: 2.75rem;
		}

		.post-title {
			font-size: 1.75rem;
		}
	}

	@media (max-width: 600px) {
		.posts-page {
			padding: var(--spacing-6) var(--spacing-4) var(--spacing-12);
		}

		.page-title {
			font-size: 2.25rem;
		}

		.post-title {
			font-size: 1.5rem;
		}

		.post-content {
			padding: var(--spacing-4);
		}
	}
</style>