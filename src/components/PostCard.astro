---
import type { MediaValue } from 'emdash'
import { Image } from 'emdash/ui'
import { getRelativeLocaleUrl } from 'astro:i18n'
import { formatDate, type Locale } from '../i18n/utils'

interface Props {
	title: string
	excerpt?: string
	featuredImage?: MediaValue | string
	href: string
	date?: Date
	tags?: Array<{ slug: string; label: string }>
	locale?: Locale
}

const {
	title,
	excerpt,
	featuredImage,
	href,
	date,
	tags,
	locale = 'es',
} = Astro.props

const formattedDate = date ? formatDate(date, locale) : null
---

<article class="post-card">
	{
		featuredImage ? (
			<a href={href} class="card-image-link">
				<div class="card-image">
					<Image image={featuredImage} />
				</div>
			</a>
		) : null
	}
	<div class="card-body">
		{formattedDate && <span class="card-date">{formattedDate}</span>}
		<a href={href} class="card-title-link">
			<h2 class="card-title">{title}</h2>
		</a>
		{excerpt && <p class="card-excerpt">{excerpt}</p>}
	</div>
	{
		tags && tags.length > 0 && (
			<div class="card-tags">
				{tags.slice(0, 3).map((tag) => (
					<a href={getRelativeLocaleUrl(locale, `/tag/${tag.slug}`)} class="card-tag">
						{tag.label}
					</a>
				))}
			</div>
		)
	}
</article>

<style>
	.post-card {
		display: flex;
		flex-direction: column;
	}

	.card-image-link {
		display: block;
		overflow: hidden;
		margin-bottom: var(--spacing-4);
	}

	.card-image {
		aspect-ratio: 16 / 10;
		overflow: hidden;
		background: var(--color-sand);
	}

	.card-image img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		transition: transform 0.3s ease;
	}

	.card-image-link:hover .card-image img {
		transform: scale(1.03);
	}

	.card-body {
		flex: 1;
	}

	.card-date {
		font-family: var(--font-sans);
		font-size: var(--font-size-sm);
		color: var(--color-muted);
	}

	.card-title-link {
		display: block;
		text-decoration: none;
		color: inherit;
		margin-top: var(--spacing-2);
	}

	.card-title {
		font-family: var(--font-serif, var(--font-sans));
		font-size: var(--font-size-xl);
		font-weight: 700;
		line-height: var(--leading-snug);
		transition: color var(--transition-fast);
	}

	.card-title-link:hover .card-title {
		color: var(--color-text-secondary);
	}

	.card-excerpt {
		font-family: var(--font-sans);
		font-size: var(--font-size-base);
		line-height: var(--leading-relaxed);
		color: var(--color-text-secondary);
		margin-top: var(--spacing-2);
		display: -webkit-box;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}

	.card-tags {
		display: flex;
		flex-wrap: wrap;
		gap: var(--spacing-2);
		margin-top: var(--spacing-3);
	}

	.card-tag {
		display: inline-block;
		padding: var(--tag-padding-y) var(--spacing-3);
		font-family: var(--font-sans);
		font-size: var(--font-size-xs);
		color: var(--color-text);
		background: var(--color-sand);
		text-decoration: none;
		transition: opacity var(--transition-fast);
	}

	.card-tag:hover {
		opacity: 0.8;
	}
</style>